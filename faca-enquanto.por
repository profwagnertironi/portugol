programa {
  funcao inicio() {
    inteiro contador = 5 // inicializa
    faca{
      escreva(contador , "\n")
      contador = contador - 1 // decremento
    }enquanto(contador > 0) // teste para interromper a repetição
    contador = 0 // inicializa
    
    faca{
      escreva(contador , "\n")
      contador = contador + 1 // incremento
    }enquanto(contador < 5) // teste para interromper


  }
}
